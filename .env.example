# .env.example - copy to .env and fill in real values. Do NOT commit .env.

# SPGCI API Credentials
SPGCI_USERNAME=""
SPGCI_PASSWORD=""

# Azure SQL Database
DB_SERVER="material-analysis.database.windows.net"
DB_NAME="Coking Coal Price Forecasting"
DB_USER=""
DB_PASSWORD=""

# OpenAI
OPENAI_API_KEY=""

# Google Drive (OAuth user credentials)
GDRIVE_FOLDER_ID=""
GDRIVE_OAUTH_CLIENT_SECRET_PATH="credentials/oauth_client_secret.json"
GDRIVE_OAUTH_TOKEN_PATH="credentials/oauth_token.json"

# Failure alerting (Gmail SMTP + App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_APP_PASSWORD=""
ALERT_EMAIL=""

# Export config
EXPORT_TABLE="coal_articles"
EXPORT_ROW_LIMIT="100"
EXPORT_ORDER_BY="id"
